# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Kotlin metadata cache (kept out of the android/ tree's own ignore scope)
.kotlin/
/android/.kotlin/

# Debug keystore & secrets (release keystore matched by *.jks below)
/android/app/debug.keystore

# Signing credentials & secrets
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
/android/local.properties

# macOS
.DS_Store

# local env files
.env*.local

# Built APKs / AABs and the local export directory
*.apk
*.aab
/apk-output/

# Test coverage
coverage/

# ZCode session scratch (e.g. plan-sess_*.md); commands/skills under .zcode/ are tracked
.zcode/plans/
