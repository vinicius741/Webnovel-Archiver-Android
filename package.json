{
  "name": "webnovel-archiver",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src app --ext .ts,.tsx",
    "lint:fix": "eslint src app --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test:coverage"
  },
  "dependencies": {
    "@logicwind/react-native-fold-detection": "^0.3.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "buffer": "^6.0.3",
    "cheerio": "^1.2.0",
    "events": "^3.3.0",
    "expo": "~54.0.0",
    "expo-background-task": "~1.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "jszip": "^3.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-image-viewing": "^0.2.2",
    "react-native-pager-view": "6.9.1",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "tts-media-session": "./modules/tts-media-session",
    "typescript": "~5.9.2",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jest-fetch-mock": "^3.0.3",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@logicwind/react-native-fold-detection",
          "@notifee/react-native",
          "tts-media-session"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "overrides": {
    "react-dom": "19.1.0",
    "react-test-renderer": "19.1.0"
  }
}
