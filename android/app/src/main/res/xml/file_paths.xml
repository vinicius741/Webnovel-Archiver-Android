<?xml version="1.0" encoding="utf-8"?>
<!--
  Narrowed FileProvider scope (Reliability R10). Previously exposed the entire files/ and cache/
  roots via `path="."`; now only the dedicated export/share subdirectories under the app data root
  are shareable: generated EPUBs, JSON/ZIP backups, and exported cleanup rules. Private story JSON
  and chapter HTML are never shared and are no longer reachable through the provider.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
  <files-path name="epubs" path="webnovel_archiver/epubs/" />
  <files-path name="backups" path="webnovel_archiver/backups/" />
  <cache-path name="restore-exports" path="webnovel_restore/" />
</paths>
